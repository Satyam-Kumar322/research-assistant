# ─── Application Settings ─────────────────────────────────────────────────────
APP_NAME="Intelligent Research Assistant"
DEBUG=True

# ─── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters

# JWT token expiry in minutes (default: 60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development — no setup needed)
# DATABASE_URL=sqlite:///./research_assistant.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://username:password@localhost:5432/research_assistant_db
DATABASE_URL=sqlite:///./research_assistant.db

# ─── OAuth (Optional) ─────────────────────────────────────────────────────────
# Google OAuth (via Firebase or Google Cloud)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
